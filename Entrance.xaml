<Window x:Class="kurs.Entrance"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход"
        Height="1024"
        Width="1440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F4F4F4">

    <Grid>

        <TextBlock Text="Вход"
                   FontSize="52"
                   FontFamily="Times New Roman"
                   HorizontalAlignment="Center"
                   Margin="0,180,0,0"
                   VerticalAlignment="Top"/>

        <!-- Крестик -->

        <Button Width="45"
                Height="45"
                Content="×"
                FontSize="24"
                Background="Transparent"
                BorderBrush="Transparent"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,170,290,0"
                Click="CloseButton_Click"/>

        <!-- Почта / Телефон -->

        <Border Width="440"
                Height="50"
                CornerRadius="8"
                BorderBrush="#BDBDBD"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,300,0,0">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button x:Name="EmailButton"
                        Content="Почта"
                        BorderThickness="0"
                        FontSize="20"
                        Background="White"
                        Click="EmailButton_Click"/>

                <Button x:Name="PhoneButton"
                        Grid.Column="1"
                        Content="Телефон"
                        BorderThickness="0"
                        FontSize="20"
                        Background="#D9D9D9"
                        Click="PhoneButton_Click"/>

            </Grid>

        </Border>

        <!-- Логин -->

        <Grid Width="640"
              Height="50"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Margin="0,400,0,0">

            <TextBox x:Name="LoginBox"
                     FontSize="20"
                     TextChanged="LoginBox_TextChanged"/>

            <TextBlock x:Name="LoginPlaceholder"
                       Text="Введите номер телефона"
                       Foreground="Gray"
                       FontSize="20"
                       Margin="15,10,0,0"
                       IsHitTestVisible="False"/>
        </Grid>

        <!-- Пароль -->

        <Grid Width="640"
              Height="50"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Margin="0,470,0,0">

            <PasswordBox x:Name="PasswordBox"
                         FontSize="20"
                         PasswordChanged="PasswordBox_PasswordChanged"/>

            <TextBlock x:Name="PasswordPlaceholder"
                       Text="Введите пароль"
                       Foreground="Gray"
                       FontSize="20"
                       Margin="15,10,0,0"
                       IsHitTestVisible="False"/>
        </Grid>

        <!-- Войти -->

        <Button Width="350"
                Height="65"
                Content="Войти"
                FontSize="24"
                Background="#4A4A4A"
                Foreground="White"
                BorderThickness="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,600,0,0"
                Click="LoginButton_Click"/>

        <!-- Регистрация -->

        <Button Content="Еще нет аккаунта"
                FontSize="18"
                Background="Transparent"
                BorderThickness="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,680,0,0"
                Click="RegistrationButton_Click"/>

    </Grid>

</Window>