<Window x:Class="kurs.Service"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:kurs"
        mc:Ignorable="d"
        Title="Услуги"
        WindowState="Maximized"
        Background="#ECECEC">

    <Window.Resources>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

    </Window.Resources>

    <Viewbox Stretch="Uniform">

        <Canvas Width="1440"
                Height="1024">

            <!-- Шапка -->

            <Border Width="1440"
                    Height="115"
                    Background="#F2F2F2"
                    Canvas.Left="0"
                    Canvas.Top="0"/>

            <!-- Логотип -->

            <Image Source="Images/logo.png"
                   Width="72"
                   Height="46"
                   Canvas.Left="80"
                   Canvas.Top="35"/>

            <TextBlock Text="МУСУБИ"
                       FontSize="26"
                       FontFamily="Times New Roman"
                       Canvas.Left="165"
                       Canvas.Top="42"/>

            <!-- Меню -->

            <Button Content="Главная"
                    Style="{StaticResource MenuButtonStyle}"
                    Canvas.Left="760"
                    Canvas.Top="45"
                    Click="MainButton_Click"/>

            <Button Content="Каталог"
                    Style="{StaticResource MenuButtonStyle}"
                    Canvas.Left="870"
                    Canvas.Top="45"
                    Click="CatalogButton_Click"/>

            <Button Content="Услуги"
                    Style="{StaticResource MenuButtonStyle}"
                    Canvas.Left="980"
                    Canvas.Top="45"
                    Click="ServicesButton_Click"/>

            <Button Content="Отзывы"
                    Style="{StaticResource MenuButtonStyle}"
                    Canvas.Left="1090"
                    Canvas.Top="45"
                    Click="ReviewsButton_Click"/>

            <Button Content="О нас"
                    Style="{StaticResource MenuButtonStyle}"
                    Canvas.Left="1200"
                    Canvas.Top="45"
                    Click="AboutButton_Click"/>

            <!-- Профиль -->

            <Button Width="50"
                    Height="50"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Canvas.Left="1305"
                    Canvas.Top="32"
                    Click="ProfileButton_Click">

                <Image Source="Images/user.png"
                       Width="40"
                       Height="40"/>

            </Button>

            <!-- Заголовок -->

            <TextBlock Text="Услуги"
                       FontSize="58"
                       FontFamily="Times New Roman"
                       Foreground="Black"
                       Canvas.Left="80"
                       Canvas.Top="180"/>

            <!-- Карточка 1 -->

            <Border Width="348"
                    Height="321"
                    CornerRadius="8"
                    Canvas.Left="114"
                    Canvas.Top="300">

                <Image Source="Images/service1.png"
                       Stretch="Fill"/>

            </Border>

            <TextBlock Text="Консультация стилиста"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Canvas.Left="114"
                       Canvas.Top="645"/>

            <TextBlock Width="330"
                       TextWrapping="Wrap"
                       FontSize="16"
                       Foreground="#333333"
                       Text="Поможем подобрать фасон, ткань и посадку под вашу фигуру"
                       Canvas.Left="114"
                       Canvas.Top="695"/>

            <Button Content="Записаться →"
                Width="170"
                Height="45"
                FontSize="18"
                Background="#4A4A4A"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Canvas.Left="114"
                Canvas.Top="780"
                Click="RequestButton_Click"/>

            <!-- Карточка 2 -->

            <Border Width="348"
                    Height="321"
                    CornerRadius="8"
                    Canvas.Left="546"
                    Canvas.Top="300">

                <Image Source="Images/service2.png"
                       Stretch="Fill"/>

            </Border>

            <TextBlock Text="Пошив на заказ"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Canvas.Left="546"
                       Canvas.Top="645"/>

            <TextBlock Width="330"
                       TextWrapping="Wrap"
                       FontSize="16"
                       Foreground="#333333"
                       Text="Создаем изделие по вашим меркам и пожеланиям"
                       Canvas.Left="546"
                       Canvas.Top="695"/>

            <Button Content="Записаться →"
                Width="170"
                Height="45"
                FontSize="18"
                Background="#4A4A4A"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Canvas.Left="546"
                Canvas.Top="780"
                Click="RequestButton_Click"/>

            <!-- Карточка 3 -->

            <Border Width="348"
                    Height="321"
                    CornerRadius="8"
                    Canvas.Left="978"
                    Canvas.Top="300">

                <Image Source="Images/service3.png"
                       Stretch="Fill"/>

            </Border>

            <TextBlock Text="Переделка одежды"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Canvas.Left="978"
                       Canvas.Top="645"/>

            <TextBlock Width="330"
                       TextWrapping="Wrap"
                       FontSize="16"
                       Foreground="#333333"
                       Text="Коррекция посадки, длины и деталей изделия"
                       Canvas.Left="978"
                       Canvas.Top="695"/>

            <Button Content="Записаться →"
                Width="170"
                Height="45"
                FontSize="18"
                Background="#4A4A4A"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Canvas.Left="978"
                Canvas.Top="780"
                Click="RequestButton_Click"/>

        </Canvas>

    </Viewbox>

</Window>