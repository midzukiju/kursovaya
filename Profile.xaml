<Window x:Class="kurs.Profile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Профиль"
        Height="1024"
        Width="1440"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F4F4F4">

    <Window.Resources>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="35,0"/>
        </Style>

    </Window.Resources>

    <Viewbox Stretch="Uniform">

        <Grid Width="1440" Height="1024">

            <!-- Шапка -->

            <Border Height="115"
        VerticalAlignment="Top"
        Background="#F2F2F2">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <!-- Логотип -->

                    <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="80,0,0,0">

                        <Image Source="Images/logo.png"
                   Width="72"
                   Height="46"/>

                        <TextBlock Text="МУСУБИ"
                       Margin="15,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="26"
                       FontFamily="Times New Roman"
                       Foreground="#111111"/>

                    </StackPanel>

                    <!-- Меню -->

                    <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                        <Button Content="Главная"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="MainButton_Click"/>

                        <Button Content="Каталог"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="CatalogButton_Click"/>

                        <Button Content="Услуги"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="ServicesButton_Click"/>

                        <Button Content="Отзывы"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="ReviewsButton_Click"/>

                        <Button Content="О нас"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="AboutButton_Click"/>

                    </StackPanel>

                    <!-- Профиль -->

                    <Button Grid.Column="2"
                Width="50"
                Height="50"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand">

                        <Image Source="Images/user.png"
                   Width="40"
                   Height="40"/>

                    </Button>

                </Grid>

            </Border>

            <!-- Заголовок -->

            <TextBlock Text="Мой профиль"
                       FontSize="54"
                       Margin="80,180,0,0"
                       VerticalAlignment="Top"/>

            <!-- Аватар -->

            <Border Width="150"
                    Height="150"
                    CornerRadius="75"
                    BorderBrush="#CFCFCF"
                    BorderThickness="1"
                    Margin="120,310,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">

                <TextBlock Text="А"
                           FontSize="64"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Информация -->

            <StackPanel Margin="350,320,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">

                <TextBlock x:Name="UserNameText"
                           Text="Анна Иванова"
                           FontSize="28"/>

                <TextBlock x:Name="EmailText"
                           Text="annaivanova67@gmail.com"
                           FontSize="18"
                           Margin="0,15,0,0"/>

                <TextBlock x:Name="PhoneText"
                           Text="+79008112326"
                           FontSize="18"/>
            </StackPanel>

            <!-- Редактирование -->

            <Button Width="40"
                    Height="40"
                    Margin="660,315,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Click="EditProfile_Click">

                <TextBlock Text="✎"
                           FontSize="24"/>
            </Button>

            <!-- Избранное -->

            <TextBlock Text="Избранное"
                       FontSize="38"
                       Margin="120,520,0,0"
                       VerticalAlignment="Top"/>

            <!-- Товар 1 -->

            <StackPanel Margin="120,600,0,0"
                        Width="240"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">

                <Image Source="Images/item1.png"
                       Height="220"/>

                <TextBlock Text="Кофта “Солнечные дни”"
                           FontSize="16"/>

                <TextBlock Text="Лен/хлопок"/>

                <TextBlock Text="от 1000 ₽"/>

                <StackPanel Orientation="Horizontal">

                    <Button Content="Заказать"
                            Margin="0,10,20,0"
                            Click="Order1_Click"/>

                    <Button Content="🗑"
                            Margin="0,10,0,0"
                            Click="Delete1_Click"/>

                </StackPanel>

            </StackPanel>

            <!-- Товар 2 -->

            <StackPanel Margin="450,600,0,0"
                        Width="240"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">

                <Image Source="Images/item2.png"
                       Height="220"/>

                <TextBlock Text="Шорты “Пляжный ритм”"
                           FontSize="16"/>

                <TextBlock Text="Лен/хлопок"/>

                <TextBlock Text="от 800 ₽"/>

                <StackPanel Orientation="Horizontal">

                    <Button Content="Заказать"
                            Margin="0,10,20,0"
                            Click="Order2_Click"/>

                    <Button Content="🗑"
                            Margin="0,10,0,0"
                            Click="Delete2_Click"/>

                </StackPanel>

            </StackPanel>

            <!-- Товар 3 -->

            <StackPanel Margin="780,600,0,0"
                        Width="240"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">

                <Image Source="Images/item3.png"
                       Height="220"/>

                <TextBlock Text="Платье “Элегантность”"
                           FontSize="16"/>

                <TextBlock Text="Лен/хлопок"/>

                <TextBlock Text="от 2500 ₽"/>

                <StackPanel Orientation="Horizontal">

                    <Button Content="Заказать"
                            Margin="0,10,20,0"
                            Click="Order3_Click"/>

                    <Button Content="🗑"
                            Margin="0,10,0,0"
                            Click="Delete3_Click"/>

                </StackPanel>

            </StackPanel>

        </Grid>

    </Viewbox>
</Window>