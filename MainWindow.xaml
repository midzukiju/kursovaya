<Window x:Class="kurs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:kurs"
        mc:Ignorable="d"
        Title="МУСУБИ"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#E9E9E9">

    <Window.Resources>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="35,0"/>
        </Style>

    </Window.Resources>

    <Viewbox Stretch="Uniform">

        <Grid Width="1440" Height="1024">

            <Grid.RowDefinitions>
                <RowDefinition Height="115"/>
                <RowDefinition Height="445"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ================= HEADER ================= -->

            <Border Grid.Row="0"
                    Background="#F2F2F2">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <!-- Логотип -->

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="80,0,0,0">

                        <Image Source="Images/logo.png"
                               Width="72"
                               Height="46"/>

                        <TextBlock Text="МУСУБИ"
                                   Margin="15,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="26"
                                   FontFamily="Times New Roman"
                                   Foreground="#111111"/>
                    </StackPanel>

                    <!-- Меню -->

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <Button Content="Главная"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="MainButton_Click"/>

                        <Button Content="Каталог"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="CatalogButton_Click"/>

                        <Button Content="Услуги"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="ServicesButton_Click"/>

                        <Button Content="Отзывы"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="ReviewsButton_Click"/>

                        <Button Content="О нас"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="AboutButton_Click"/>

                    </StackPanel>

                    <!-- Профиль -->

                    <Button Grid.Column="2"
                            Width="50"
                            Height="50"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="ProfileButton_Click">

                        <Image Source="Images/user.png"
                               Width="40"
                               Height="40"/>
                    </Button>

                </Grid>

            </Border>

            <!-- ================= БЛОК С ФОТО ================= -->

            <Border Grid.Row="1"
                    Background="#4A4A4A">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="230"
                            Height="295"
                            CornerRadius="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                        <Image Source="Images/model1.png"
                               Stretch="Fill"/>
                    </Border>

                    <Border Grid.Column="1"
                            Width="230"
                            Height="295"
                            CornerRadius="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                        <Image Source="Images/model2.png"
                               Stretch="Fill"/>
                    </Border>

                    <Border Grid.Column="2"
                            Width="230"
                            Height="295"
                            CornerRadius="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                        <Image Source="Images/model3.png"
                               Stretch="Fill"/>
                    </Border>

                    <Border Grid.Column="3"
                            Width="230"
                            Height="295"
                            CornerRadius="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                        <Image Source="Images/model4.png"
                               Stretch="Fill"/>
                    </Border>

                </Grid>

            </Border>

            <!-- ================= НИЖНИЙ БЛОК ================= -->

            <Grid Grid.Row="2">

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,60,0,0">

                    <TextBlock Text="Твой уникальный стиль"
                               FontSize="64"
                               FontFamily="Times New Roman"
                               HorizontalAlignment="Center"
                               Foreground="#10151D"/>

                    <TextBlock Text="Создаем с вниманием к деталям"
                               FontSize="24"
                               Margin="0,15,0,0"
                               HorizontalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,70,0,0">

                        <Button Content="Заказать пошив"
                                Width="435"
                                Height="80"
                                FontSize="24"
                                Margin="0,0,60,0"
                                Foreground="White"
                                Background="#4A4A4A"
                                BorderThickness="0"/>

                        <Button Content="Переделка одежды"
                                Width="435"
                                Height="80"
                                FontSize="24"
                                Foreground="White"
                                Background="#4A4A4A"
                                BorderThickness="0"/>

                    </StackPanel>

                </StackPanel>

            </Grid>

        </Grid>

    </Viewbox>

</Window>