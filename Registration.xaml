<Window x:Class="kurs.Registration"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация"
        Width="1440"
        Height="1024"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F4F4F4">

    <Grid>

        <TextBlock Text="Регистрация"
                   FontSize="52"
                   FontFamily="Times New Roman"
                   HorizontalAlignment="Center"
                   Margin="0,130,0,0"
                   VerticalAlignment="Top"/>

        <!-- Крестик -->

        <Button x:Name="CloseButton"
                Width="45"
                Height="45"
                FontSize="24"
                Content="×"
                Background="Transparent"
                BorderBrush="Transparent"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,120,290,0"
                Click="CloseButton_Click"/>

        <!-- Переключатель -->

        <Border Width="440"
                Height="50"
                CornerRadius="8"
                BorderBrush="#BDBDBD"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,250,0,0">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button x:Name="EmailButton"
                        Content="Почта"
                        FontSize="20"
                        Background="White"
                        BorderThickness="0"
                        Click="EmailButton_Click"/>

                <Button x:Name="PhoneButton"
                        Grid.Column="1"
                        Content="Телефон"
                        FontSize="20"
                        Background="#D9D9D9"
                        BorderThickness="0"
                        Click="PhoneButton_Click"/>

            </Grid>

        </Border>

        <!-- Имя -->

        <Grid Width="640"
              Height="50"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Margin="0,360,0,0">

            <TextBox x:Name="NameBox"
                     FontSize="20"
                     TextChanged="NameBox_TextChanged"/>

            <TextBlock x:Name="NamePlaceholder"
                       Text="Введите имя"
                       Foreground="Gray"
                       FontSize="20"
                       Margin="15,10,0,0"
                       IsHitTestVisible="False"/>
        </Grid>

        <!-- Контакт -->

        <Grid Width="640"
              Height="50"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Margin="0,430,0,0">

            <TextBox x:Name="ContactBox"
                     FontSize="20"
                     TextChanged="ContactBox_TextChanged"/>

            <TextBlock x:Name="ContactPlaceholder"
                       Text="Введите номер телефона"
                       Foreground="Gray"
                       FontSize="20"
                       Margin="15,10,0,0"
                       IsHitTestVisible="False"/>
        </Grid>

        <!-- Пароль -->

        <Grid Width="640"
              Height="50"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Margin="0,500,0,0">

            <PasswordBox x:Name="PasswordBox"
                         FontSize="20"
                         PasswordChanged="PasswordBox_PasswordChanged"/>

            <TextBlock x:Name="PasswordPlaceholder"
                       Text="Введите пароль"
                       Foreground="Gray"
                       FontSize="20"
                       Margin="15,10,0,0"
                       IsHitTestVisible="False"/>
        </Grid>

        <!-- Регистрация -->

        <Button x:Name="RegisterButton"
                Content="Зарегистрироваться"
                Width="350"
                Height="65"
                FontSize="24"
                Background="#4A4A4A"
                Foreground="White"
                BorderThickness="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,610,0,0"
                Click="RegisterButton_Click"/>

        <!-- Уже есть аккаунт -->

        <Button x:Name="LoginButton"
                Content="Уже есть аккаунт"
                FontSize="18"
                Background="Transparent"
                BorderThickness="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,690,0,0"
                Click="LoginButton_Click"/>

    </Grid>
</Window>