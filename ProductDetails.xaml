<Window x:Class="kurs.ProductDetails"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка товара"
        Width="1440"
        Height="1024"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#E9E9E9">

    <Viewbox Stretch="Uniform">

        <Grid Width="1440" Height="1024">

            <!-- Кнопка назад -->
            <Button Width="50"
                    Height="50"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="70,70,0,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BackButton_Click">

                <TextBlock Text="←"
                           FontSize="42"
                           FontFamily="Segoe UI"
                           Foreground="Black"/>
            </Button>

            <!-- Фото -->
            <Border Width="500"
                    Height="650"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="130,180,0,0"
                    CornerRadius="8">

                <Image Source="Images/sarafan.png"
                       Stretch="Fill"/>
            </Border>

            <!-- Правая часть -->
            <StackPanel Width="560"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="700,190,0,0">

                <TextBlock Text='Сарафан "Нежность"'
                           FontSize="48"
                           FontFamily="Times New Roman"
                           Foreground="Black"/>

                <TextBlock Margin="0,70,0,0"
                           FontSize="20"
                           Foreground="#333333"
                           TextWrapping="Wrap"
                           Width="560"
                           Text="Модель для моментов истинного расслабления. Широкие штанины мягко драпируются при движении, создавая изящный и при этом непринуждённый силуэт. Эти брюки созданы для неспешного утра, чтения любимых книг и отдыха в стиле slow living."/>

                <TextBlock Margin="0,70,0,0"
                           FontSize="18"
                           Foreground="#333333"
                           TextWrapping="Wrap">
Материал: лен / хлопок

Посадка: свободная

Сезон: лето / демисезон
                </TextBlock>

                <TextBlock Margin="0,60,0,0"
                           FontSize="28"
                           Foreground="#222222"
                           Text="Срок изготовления от 5 дней"/>

                <TextBlock Margin="0,30,0,0"
                           FontSize="32"
                           Foreground="#222222"
                           Text="от 1500 ₽"/>

                <StackPanel Orientation="Horizontal"
                            Margin="0,60,0,0">

                    <Button Width="250"
                            Height="65"
                            Content="Заказать"
                            FontSize="24"
                            Background="#4A4A4A"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="OrderButton_Click"/>

                    <Button Width="250"
                            Height="65"
                            Margin="50,0,0,0"
                            Content="В избранное"
                            FontSize="24"
                            Background="#E9E9E9"
                            BorderBrush="#6B6B6B"
                            BorderThickness="1"
                            Foreground="#4A4A4A"
                            Cursor="Hand"
                            Click="FavoriteButton_Click"/>
                </StackPanel>

            </StackPanel>

        </Grid>

    </Viewbox>
</Window>