<Window x:Class="kurs.Administrator"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель администратора" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <TabControl>
            <!-- Вкладка Клиенты -->
            <TabItem Header="Клиенты">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Обновить" Width="100" Height="30" Margin="0,0,5,0" Click="BtnRefreshClients_Click"/>
                        <Button Content="Добавить" Width="100" Height="30" Margin="0,0,5,0" Click="BtnAddClient_Click"/>
                        <Button Content="Удалить" Width="100" Height="30" Click="BtnDeleteClient_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="DgClients" Grid.Row="1" 
                              AutoGenerateColumns="True"
                              IsReadOnly="True" 
                              CanUserAddRows="False"/>
                </Grid>
            </TabItem>

            <!-- Вкладка Сотрудники -->
            <TabItem Header="Сотрудники">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Обновить" Width="100" Height="30" Margin="0,0,5,0" Click="BtnRefreshEmployees_Click"/>
                        <Button Content="Добавить" Width="100" Height="30" Margin="0,0,5,0" Click="BtnAddEmployee_Click"/>
                        <Button Content="Удалить" Width="100" Height="30" Click="BtnDeleteEmployee_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="DgEmployees" Grid.Row="1" 
                              AutoGenerateColumns="True"
                              IsReadOnly="True" 
                              CanUserAddRows="False"/>
                </Grid>
            </TabItem>

            <!-- Вкладка Заказы -->
            <TabItem Header="Заказы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Обновить" Width="100" Height="30" Margin="0,0,5,0" Click="BtnRefreshOrders_Click"/>
                        <Button Content="Добавить" Width="100" Height="30" Margin="0,0,5,0" Click="BtnAddOrder_Click"/>
                        <Button Content="Удалить" Width="100" Height="30" Click="BtnDeleteOrder_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="DgOrders" Grid.Row="1" 
                              AutoGenerateColumns="True"
                              IsReadOnly="True" 
                              CanUserAddRows="False"/>
                </Grid>
            </TabItem>

            <!-- Вкладка Индивидуальные заказы -->
            <TabItem Header="Индивидуальные заказы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Обновить" Width="100" Height="30" Margin="0,0,5,0" Click="BtnRefreshIndOrders_Click"/>
                        <Button Content="Добавить" Width="100" Height="30" Margin="0,0,5,0" Click="BtnAddIndOrder_Click"/>
                        <Button Content="Удалить" Width="100" Height="30" Click="BtnDeleteIndOrder_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="DgIndOrders" Grid.Row="1" 
                              AutoGenerateColumns="True"
                              IsReadOnly="True" 
                              CanUserAddRows="False"/>
                </Grid>
            </TabItem>

            <!-- Вкладка Материалы -->
            <TabItem Header="Материалы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Обновить" Width="100" Height="30" Margin="0,0,5,0" Click="BtnRefreshMaterials_Click"/>
                        <Button Content="Добавить" Width="100" Height="30" Margin="0,0,5,0" Click="BtnAddMaterial_Click"/>
                        <Button Content="Удалить" Width="100" Height="30" Click="BtnDeleteMaterial_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="DgMaterials" Grid.Row="1" 
                              AutoGenerateColumns="True"
                              IsReadOnly="True" 
                              CanUserAddRows="False"/>
                </Grid>
            </TabItem>

            <!-- Вкладка Поставки -->
            <TabItem Header="Поставки">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Обновить" Width="100" Height="30" Margin="0,0,5,0" Click="BtnRefreshSupplies_Click"/>
                        <Button Content="Добавить" Width="100" Height="30" Margin="0,0,5,0" Click="BtnAddSupply_Click"/>
                        <Button Content="Удалить" Width="100" Height="30" Click="BtnDeleteSupply_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="DgSupplies" Grid.Row="1" 
                              AutoGenerateColumns="True"
                              IsReadOnly="True" 
                              CanUserAddRows="False"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>