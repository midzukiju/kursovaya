<Window x:Class="kurs.Catalog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Каталог"
        Width="1440"
        Height="1024"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F4F4F4">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="35,0"/>
        </Style>
    </Window.Resources>
    <Viewbox Stretch="Uniform">
        <Grid Width="1440" Height="1024">
            <!-- Шапка -->
            <Border Height="115"
        VerticalAlignment="Top"
        Background="#F2F2F2">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <!-- Логотип -->

                    <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="80,0,0,0">

                        <Image Source="Images/logo.png"
                   Width="72"
                   Height="46"/>

                        <TextBlock Text="МУСУБИ"
                       Margin="15,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="26"
                       FontFamily="Times New Roman"
                       Foreground="#111111"/>

                    </StackPanel>

                    <!-- Меню -->

                    <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                        <Button Content="Главная"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="MainButton_Click"/>

                        <Button Content="Каталог"
                    Style="{StaticResource MenuButtonStyle}"/>

                        <Button Content="Услуги"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="ServicesButton_Click"/>

                        <Button Content="Отзывы"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="ReviewsButton_Click"/>

                        <Button Content="О нас"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="AboutButton_Click"/>

                    </StackPanel>

                    <!-- Профиль -->

                    <Button Grid.Column="2"
                Width="50"
                Height="50"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Click="ProfileButton_Click">

                        <Image Source="Images/user.png"
                   Width="40"
                   Height="40"/>

                    </Button>

                </Grid>

            </Border>
            <!-- Заголовок -->
            <TextBlock Text="Каталог" FontSize="54" Margin="80,180,0,0" VerticalAlignment="Top"/>
            <!-- Поиск -->
            <Border Width="1140" Height="60" CornerRadius="30" BorderBrush="#BEBEBE" BorderThickness="1" Margin="130,330,130,0" VerticalAlignment="Top">
                <Grid>
                    <TextBox x:Name="SearchBox" GotFocus="SearchBox_GotFocus"
                        LostFocus="SearchBox_LostFocus" Width="980" Height="40" BorderThickness="0" Background="Transparent" FontSize="20" Margin="30,0,0,0" VerticalContentAlignment="Center" Text="Поиск..."/>
                    <Image Source="Images/search.png" Width="30" Height="30" HorizontalAlignment="Right" Margin="0,0,35,0"/>
                </Grid>
            </Border>
            <!-- Фильтры -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,430,0,0" VerticalAlignment="Top">
                <ComboBox Width="230" Height="50" Margin="20,0" FontSize="18">
                    <ComboBoxItem Content="Категория" IsEnabled="False"/>
                    <ComboBoxItem Content="Платье"/>
                    <ComboBoxItem Content="Брюки"/>
                    <ComboBoxItem Content="Кофта"/>
                </ComboBox>
                <ComboBox Width="230" Height="50" Margin="20,0" FontSize="18">
                    <ComboBoxItem Content="Цена до" IsEnabled="False"/>
                    <ComboBoxItem Content="до 1000"/>
                    <ComboBoxItem Content="до 2000"/>
                    <ComboBoxItem Content="до 5000"/>
                </ComboBox>
                <ComboBox Width="230" Height="50" Margin="20,0" FontSize="18">
                    <ComboBoxItem Content="Сезон" IsEnabled="False"/>
                    <ComboBoxItem Content="Осень"/>
                    <ComboBoxItem Content="Зима"/>
                    <ComboBoxItem Content="Лето"/>
                    <ComboBoxItem Content="Весна"/>
                </ComboBox>
            </StackPanel>
            <!-- Рекомендуем -->
            <TextBlock Text="Рекомендуем" FontSize="36" Margin="95,540,0,0" VerticalAlignment="Top"/>
            <!-- Карточки -->
            <WrapPanel Margin="95,620,95,0" VerticalAlignment="Top">
                <!-- Товар 1 -->
                <StackPanel Width="280" Margin="15">
                    <Button Background="Transparent" BorderThickness="0" Click="Product_Click">
                        <Image Source="Images/dress.png" Width="240" Height="220"/>
                    </Button>
                    <TextBlock Text="Сарафан “Нежность”" FontSize="16"/>
                    <TextBlock Text="Лен/хлопок" Foreground="Gray"/>
                    <TextBlock Text="от 1500 ₽"/>
                </StackPanel>
                <!-- Товар 2 -->
                <StackPanel Width="280" Margin="15">
                    <Button Background="Transparent" BorderThickness="0" Click="Product_Click">
                        <Image Source="Images/pants.png" Width="240" Height="220"/>
                    </Button>
                    <TextBlock Text="Брюки “Дзен”" FontSize="16"/>
                    <TextBlock Text="Лен/хлопок" Foreground="Gray"/>
                    <TextBlock Text="от 2000 ₽"/>
                </StackPanel>
                <!-- Товар 3 -->
                <StackPanel Width="280" Margin="15">
                    <Button Background="Transparent" BorderThickness="0" Click="Product_Click">
                        <Image Source="Images/blouse.png" Width="240" Height="220"/>
                    </Button>
                    <TextBlock Text="Кофта “Солнечные дни”" FontSize="16"/>
                    <TextBlock Text="Лен/хлопок" Foreground="Gray"/>
                    <TextBlock Text="от 1000 ₽"/>
                </StackPanel>
                <!-- Товар 4 -->
                <StackPanel Width="280" Margin="15">
                    <Button Background="Transparent" BorderThickness="0" Click="Product_Click">
                        <Image Source="Images/shorts.png" Width="240" Height="220"/>
                    </Button>
                    <TextBlock Text="Шорты “Пляжный ритм”" FontSize="16"/>
                    <TextBlock Text="Лен/хлопок" Foreground="Gray"/>
                    <TextBlock Text="от 800 ₽"/>
                </StackPanel>
            </WrapPanel>
        </Grid>
    </Viewbox>
</Window>