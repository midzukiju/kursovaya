<Window x:Class="kurs.RequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заявка"
        Width="1440"
        Height="1024"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F4F4F4">
    
    <Viewbox Stretch="Uniform">
        <Grid>

        <!-- Стрелка -->

        <Button Width="50"
                Height="50"
                FontSize="30"
                Content="←"
                Background="Transparent"
                BorderThickness="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="70,70,0,0"
                Click="BackButton_Click"/>

        <!-- Заголовок -->

        <TextBlock Text="Оставить заявку"
                   FontSize="42"
                   FontFamily="Times New Roman"
                   Margin="90,170,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

        <Border Width="1090"
                Height="4"
                Background="#4A4A4A"
                Margin="175,250,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"/>

        <!-- Имя -->

        <TextBlock Text="Имя"
                   FontSize="20"
                   Margin="185,350,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="NameBox"
                 Width="830"
                 Height="50"
                 FontSize="18"
                 Margin="395,335,0,0"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"/>

        <!-- Телефон -->

        <TextBlock Text="Телефон"
                   FontSize="20"
                   Margin="185,425,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="PhoneBox"
                 Width="830"
                 Height="50"
                 FontSize="18"
                 Margin="395,410,0,0"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"/>

        <!-- Email -->

        <TextBlock Text="Email"
                   FontSize="20"
                   Margin="185,500,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="EmailBox"
                 Width="830"
                 Height="50"
                 FontSize="18"
                 Margin="395,485,0,0"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"/>

        <!-- Комментарий -->

        <TextBlock Text="Комментарий"
                   FontSize="20"
                   Margin="185,595,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

        <TextBox x:Name="CommentBox"
                 Width="830"
                 Height="130"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 FontSize="18"
                 Margin="395,580,0,0"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"/>

        <!-- Назад -->

        <Button Width="250"
                Height="65"
                Content="Назад"
                FontSize="22"
                Background="#F4F4F4"
                BorderBrush="#666"
                BorderThickness="1"
                Margin="450,790,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Click="BackButton_Click"/>

        <!-- Отправить -->

        <Button Width="250"
                Height="65"
                Content="Отправить"
                FontSize="22"
                Background="#4A4A4A"
                Foreground="White"
                BorderThickness="0"
                Margin="750,790,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Click="SendButton_Click"/>

        <TextBlock Text="1/1"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,865,0,0"/>

    </Grid>

    </Viewbox>

</Window>